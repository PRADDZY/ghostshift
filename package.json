{
  "name": "ghostshift",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @ghostshift/shared build && pnpm --filter @ghostshift/server dev",
    "dev:web": "pnpm --filter @ghostshift/shared build && pnpm --filter @ghostshift/web dev",
    "test": "pnpm --filter @ghostshift/shared build && pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
